        "dashboard_hero": "https://images.unsplash.com/photo-1720139290958-d8676702c3ed?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTY2Nzd8MHwxfHNlYXJjaHwzfHxtb2Rlcm4lMjBjb3dvcmtpbmclMjBzcGFjZSUyMGludGVyaW9yJTIwbWluaW1hbGlzdHxlbnwwfHx8fDE3NzMwNTIxMTd8MA&ixlib=rb-4.1.0&q=85",
        "user_placeholder": "https://images.unsplash.com/photo-1720139291006-585bc5d18b3b?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTY2Nzd8MHwxfHNlYXJjaHw0fHxtb2Rlcm4lMjBjb3dvcmtpbmclMjBzcGFjZSUyMGludGVyaW9yJTIwbWluaW1hbGlzdHxlbnwwfHx8fDE3NzMwNTIxMTd8MA&ixlib=rb-4.1.0&q=85"
      }
    }
  },
  "implementation_guide": {
    "steps": [
      "1. Setup Tailwind Config: Extend colors with the 'Thryve' palette (Emerald/Slate).",
      "2. Install Fonts: Add Manrope, Public Sans, and JetBrains Mono via Google Fonts.",
      "3. Create Layout Shell: SidebarLayout with collapsible nav.",
      "4. Build Core Components: InvoiceCard, ClientRow, StatusBadge.",
      "5. Develop Invoice Builder: Complex form state management (use React Hook Form).",
      "6. Implement PDF Export: Use 'react-to-print' or 'jspdf' for the preview component."
    ],
    "universal_rules": [
      "DO NOT use gradients for backgrounds.",
      "DO NOT use 'Inter' font.",
      "Always use 'data-testid' for interactive elements.",
      "Use 'sonner' for toast notifications.",
      "Ensure all financial numbers are right-aligned and use JetBrains Mono."
    ]
  }
}